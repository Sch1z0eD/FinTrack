<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Only this flavor reaches the network. The single outbound request is the GitHub release
         check, and it runs when the user asks for it or when they switch the daily check on -
         never otherwise. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Needed to hand a downloaded APK to the package installer: the github build updates
         itself from GitHub Releases rather than through a store. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application>

        <receiver
            android:name=".update.UpdateDownloadReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- Receives the PackageInstaller session callbacks. Not exported: only the system
             holds the PendingIntent that targets it. -->
        <receiver
            android:name=".update.InstallResultReceiver"
            android:exported="false" />
    </application>

</manifest>
