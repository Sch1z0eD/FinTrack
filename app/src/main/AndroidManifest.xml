<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- A bill is due on a date, not at a moment, but CLAUDE.md fixes exact alarms for
         payments. The permission is revocable, so the scheduler falls back to an inexact
         alarm rather than crashing when it is not held. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Samsung's aggressive background management drops alarms; this lets the user waive it
         for FinTrack from the in-app settings screen. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- The app stores nothing off-device and talks to no server. The only outbound request
         is the GitHub release check, and it runs when the user asks for it or when they have
         switched the daily check on - never otherwise. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Needed to hand a downloaded APK to the package installer: this app updates itself
         from GitHub Releases rather than through a store. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".FinTrackApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FinTrack">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FinTrack">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".notification.PaymentReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".notification.LoanReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".notification.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.BalanceWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/balance_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.NextPaymentWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/next_payment_widget_info" />
        </receiver>

        <receiver
            android:name=".update.UpdateDownloadReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
            </intent-filter>
        </receiver>

        <!-- Receives the PackageInstaller session callbacks. Not exported: only the system
             holds the PendingIntent that targets it. -->
        <receiver
            android:name=".update.InstallResultReceiver"
            android:exported="false" />

        <!-- On-demand WorkManager: the app provides its own Configuration (with the Hilt
             worker factory) from FinTrackApplication, so the default startup initializer
             must be removed or it would race to initialise WorkManager without it. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
